@page "/admin/offices"
@inject ApiService Api

<PageTitle>Manage Offices</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-building me-2"></i>Offices</h2>
    <HxButton Text="Add Office" Color="ThemeColor.Primary" Icon="BootstrapIcon.PlusLg" OnClick="() => _showForm = !_showForm" />
</div>

@if (!string.IsNullOrEmpty(_error))
{
    <HxAlert Color="ThemeColor.Danger" CssClass="alert-dismissible">
        @_error
        <button type="button" class="btn-close" @onclick="() => _error = null"></button>
    </HxAlert>
}

@if (_showForm)
{
    <div class="card mb-4">
        <div class="card-body">
            <h5>@(_editId.HasValue ? "Edit" : "New") Office</h5>
            <div class="row g-3">
                <div class="col-md-2">
                    <HxInputText Label="Unit Number" @bind-Value="_formUnit" Placeholder="e.g. 101" />
                </div>
                <div class="col-md-3">
                    <HxInputText Label="Office Name" @bind-Value="_formName" Placeholder="e.g. Smile Dental" />
                </div>
                <div class="col-md-4">
                    <HxInputTags Label="Name(s)" @bind-Value="_formNames" Placeholder="Type name, press Enter" TagBadgeSettings="@(new BadgeSettings { Color=ThemeColor.Primary })" />
                </div>
                <div class="col-md-2">
                    <HxInputText Label="Phone" @bind-Value="_formPhone" Placeholder="e.g. 555-1234" />
                </div>
                <div class="col-md-4">
                    <HxInputText Label="Note" @bind-Value="_formNote" Placeholder="e.g. Suite 200, Open Mon-Fri" />
                </div>
            </div>
            <div class="mt-3">
                <HxButton Text="Save" Color="ThemeColor.Success" Icon="BootstrapIcon.CheckLg" OnClick="SaveOffice" CssClass="me-2" />
                <HxButton Text="Cancel" Color="ThemeColor.Secondary" OnClick="CancelForm" />
            </div>
        </div>
    </div>
}

@if (_offices is null)
{
    <div class="text-center py-5"><HxSpinner /></div>
}
else if (_offices.Count == 0)
{
    <HxAlert Color="ThemeColor.Info">No offices yet. Click "Add Office" to create one.</HxAlert>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Unit #</th>
                    <th>Name</th>
                    <th>Name(s)</th>
                    <th>Phone</th>
                    <th>Created</th>
                    <th style="width:120px">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var o in _offices)
                {
                    <tr>
                        <td><HxBadge Color="ThemeColor.Primary" CssClass="fs-6">@o.UnitNumber</HxBadge></td>
                        <td>@o.Name</td>
                        <td>@(o.Names.Count > 0 ? string.Join(", ", o.Names) : "—")</td>
                        <td>@(o.PhoneNumber ?? "—")</td>
                        <td>@o.CreatedAt.LocalDateTime.ToString("MMM d, yyyy")</td>
                        <td>
                            <HxButton Icon="BootstrapIcon.Pencil" Color="ThemeColor.Primary" Size="ButtonSize.Small" Outline="true" OnClick="() => EditOffice(o)" CssClass="me-1" />
                            <HxButton Icon="BootstrapIcon.Trash" Color="ThemeColor.Danger" Size="ButtonSize.Small" Outline="true" OnClick="() => DeleteOffice(o.Id)" />
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private List<OfficeDto>? _offices;
    private bool _showForm;
    private int? _editId;
    private string _formUnit = "";
    private string _formName = "";
    private List<string> _formNames = [];
    private string? _formPhone;
    private string? _formNote;
    private string? _error;

    protected override async Task OnInitializedAsync() => await LoadOffices();

    private async Task LoadOffices() => _offices = await Api.GetOfficesAsync();

    private void EditOffice(OfficeDto o)
    {
        _editId = o.Id;
        _formUnit = o.UnitNumber;
        _formName = o.Name;
        _formNames = o.Names.ToList();
        _formPhone = o.PhoneNumber;
        _formNote = o.Note;
        _showForm = true;
    }

    private void CancelForm()
    {
        _showForm = false;
        _editId = null;
        _formUnit = "";
        _formName = "";
        _formNames = [];
        _formPhone = null;
        _formNote = null;
    }

    private async Task SaveOffice()
    {
        _error = null;
        if (_editId.HasValue)
        {
            var ok = await Api.UpdateOfficeAsync(_editId.Value, new UpdateOfficeRequest(_formUnit, _formName, _formNames, _formPhone, _formNote));
            if (!ok) { _error = "Failed to update office."; return; }
        }
        else
        {
            var (ok, error) = await Api.CreateOfficeAsync(new CreateOfficeRequest(_formUnit, _formName, _formNames, _formPhone, _formNote));
            if (!ok) { _error = error; return; }
        }
        CancelForm();
        await LoadOffices();
    }

    private async Task DeleteOffice(int id)
    {
        await Api.DeleteOfficeAsync(id);
        await LoadOffices();
    }
}
