@page "/register"
@inject ApiService Api
@inject NavigationManager Nav

<PageTitle>Register</PageTitle>

<div class="row justify-content-center mt-5">
    <div class="col-md-5">
        <div class="card shadow">
            <div class="card-body">
                <h3 class="card-title text-center mb-4">Create Account</h3>

                @if (!string.IsNullOrEmpty(_error))
                {
                    <HxAlert Color="ThemeColor.Danger">@_error</HxAlert>
                }
                @if (!string.IsNullOrEmpty(_success))
                {
                    <HxAlert Color="ThemeColor.Success">@_success</HxAlert>
                }

                <EditForm Model="_model" OnValidSubmit="HandleRegister" FormName="register">
                    <div class="mb-3">
                        <HxInputText Label="Username" @bind-Value="_model.Username" />
                    </div>
                    <div class="mb-3">
                        <HxInputText Label="Password" @bind-Value="_model.Password" Type="InputType.Password" />
                    </div>
                    <div class="mb-3">
                        <HxInputText Label="Confirm Password" @bind-Value="_model.PasswordConfirm" Type="InputType.Password" />
                    </div>
                    <HxSubmit Text="Register" Color="ThemeColor.Primary" CssClass="w-100" Enabled="!_loading">
                        @if (_loading) { <HxSpinner Size="SpinnerSize.Small" CssClass="me-1" /> }
                    </HxSubmit>
                </EditForm>

                <div class="text-center mt-3">
                    <a href="/login">Already have an account? Login</a>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private RegisterModel _model = new();
    private string? _error;
    private string? _success;
    private bool _loading;

    private class RegisterModel
    {
        public string Username { get; set; } = "";
        public string Password { get; set; } = "";
        public string PasswordConfirm { get; set; } = "";
    }

    private async Task HandleRegister()
    {
        _error = null;
        _success = null;
        _loading = true;
        try
        {
            var (ok, error, isActive) = await Api.RegisterAsync(_model.Username, _model.Password, _model.PasswordConfirm);
            if (!ok) { _error = error; return; }

            _success = isActive
                ? "Admin account created! You can now login."
                : "Account created. An administrator must activate your account before you can login.";
        }
        finally
        {
            _loading = false;
        }
    }
}
