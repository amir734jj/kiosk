@page "/my-office"
@inject ApiService Api

<PageTitle>My Office</PageTitle>

<h2 class="mb-3"><i class="bi bi-building me-2"></i>My Office</h2>

@if (!string.IsNullOrEmpty(_error))
{
    <HxAlert Color="ThemeColor.Danger">@_error</HxAlert>
}
@if (!string.IsNullOrEmpty(_success))
{
    <HxAlert Color="ThemeColor.Success" CssClass="alert-dismissible">
        @_success
        <button type="button" class="btn-close" @onclick="() => _success = null"></button>
    </HxAlert>
}

@if (_loading)
{
    <div class="text-center py-5"><HxSpinner /></div>
}
else if (_office is null)
{
    <HxAlert Color="ThemeColor.Warning">
        <i class="bi bi-exclamation-triangle me-2"></i>
        No office has been assigned to your account. Contact an administrator.
    </HxAlert>
}
else
{
    <div class="card">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-3">
                    <label class="form-label">Unit Number</label>
                    <input value="@_office.UnitNumber" class="form-control" disabled />
                    <small class="text-muted">Contact admin to change unit number</small>
                </div>
                <div class="col-md-3">
                    <HxInputText Label="Office Name" @bind-Value="_name" />
                </div>
                <div class="col-md-4">
                    <HxInputTags Label="Name(s)" @bind-Value="_names" Placeholder="Type name, press Enter" TagBadgeSettings="@(new BadgeSettings { Color=ThemeColor.Primary })" />
                </div>
                <div class="col-md-3">
                    <HxInputText Label="Phone Number" @bind-Value="_phone" Placeholder="e.g. 555-1234" />
                </div>
                <div class="col-md-6">
                    <HxInputText Label="Note" @bind-Value="_note" Placeholder="e.g. Suite 200, Open Mon-Fri" />
                </div>
            </div>
            <div class="mt-3">
                <HxButton Text="Save Changes" Color="ThemeColor.Primary" Icon="BootstrapIcon.CheckLg" OnClick="Save" Enabled="!_saving">
                    @if (_saving) { <HxSpinner Size="SpinnerSize.Small" CssClass="me-1" /> }
                </HxButton>
            </div>
        </div>
    </div>
}

@code {
    private OfficeDto? _office;
    private string _name = "";
    private List<string> _names = [];
    private string? _phone;
    private string? _note;
    private bool _loading = true;
    private bool _saving;
    private string? _error;
    private string? _success;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _office = await Api.GetMyOfficeAsync();
            if (_office is not null)
            {
                _name = _office.Name;
                _names = _office.Names.ToList();
                _phone = _office.PhoneNumber;
                _note = _office.Note;
            }
        }
        catch { _error = "Failed to load office."; }
        finally { _loading = false; }
    }

    private async Task Save()
    {
        _error = null;
        _success = null;
        _saving = true;
        try
        {
            var ok = await Api.UpdateMyOfficeAsync(new UpdateOfficeRequest(_office!.UnitNumber, _name, _names, _phone, _note));
            if (ok)
            {
                _success = "Office updated successfully.";
            }
            else
            {
                _error = "Failed to update office.";
            }
        }
        catch { _error = "An error occurred."; }
        finally { _saving = false; }
    }
}
