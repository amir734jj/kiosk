@page "/display"
@layout PublicLayout
@inject ApiService Api
@implements IDisposable

<PageTitle>Office Directory</PageTitle>

<style>
    body { margin: 0; padding: 0; overflow-x: hidden; }
    .public-display {
        min-height: 100vh;
        background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
        background-size: cover;
        background-position: center;
        background-attachment: fixed;
        color: white;
        display: flex;
        flex-direction: column;
    }
    .display-header {
        background: #1a1a2e;
        border-bottom: 2px solid rgba(255, 255, 255, 0.1);
    }
    .announcements-bar {
        background: #1a1a2e;
        border-bottom: 1px solid rgba(255, 193, 7, 0.3);
    }
    .announcements-scroll {
        display: flex;
        gap: 2rem;
        overflow: hidden;
        white-space: nowrap;
    }
    .announcement-item { color: #ffc107; }
    .office-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
        gap: 1rem;
        align-content: start;
    }
    .office-card {
        background: #1a1a2e;
        border: 1px solid rgba(255, 255, 255, 0.2);
        border-radius: 12px;
        padding: 0.75rem 1rem;
        text-align: center;
    }
    .unit-badge {
        display: inline-block;
        background: #e94560;
        color: white;
        font-size: 1.5rem;
        font-weight: bold;
        padding: 0.3rem 1rem;
        border-radius: 8px;
        margin-bottom: 0.75rem;
    }
    .office-name { font-size: 1.3rem; font-weight: 600; margin-bottom: 0.5rem; }
    .person-name { color: rgba(255, 255, 255, 0.7); margin-bottom: 0; font-size: 1rem; }
    .weather-widget { display: flex; align-items: center; color: white; }
    .display-footer {
        background: transparent;
        border-top: none;
        text-align: center;
        margin-top: auto;
    }
</style>

<div class="public-display" style="@BackgroundStyle">
    <header class="display-header">
        <div class="d-flex justify-content-between align-items-center px-4 py-3">
            <h1 class="mb-0"><i class="bi bi-building me-2"></i>Office Directory</h1>
            <div class="d-flex align-items-center gap-4">
                @if (_data?.Weather is not null)
                {
                    <div class="weather-widget">
                        <i class="bi @_data.Weather.Icon fs-3"></i>
                        <span class="fs-4 ms-2">@($"{_data.Weather.TemperatureF:F0}")&deg;F</span>
                        <span class="text-white-50 ms-2">@_data.Weather.Description</span>
                    </div>
                }
                <div class="text-end">
                    <div class="fs-4"><i class="bi bi-clock me-1"></i>@DateTime.Now.ToString("h:mm tt")</div>
                    <div class="text-white-50 small">@DateTime.Now.ToString("dddd, MMMM d, yyyy")</div>
                    @if (!string.IsNullOrEmpty(_data?.TodayHoliday))
                    {
                        <div class="small"><span class="badge bg-warning text-dark"><i class="bi bi-star-fill me-1"></i>@_data.TodayHoliday</span></div>
                    }
                </div>
            </div>
        </div>
    </header>

    @if (_data is null)
    {
        <div class="d-flex justify-content-center align-items-center" style="height: 60vh">
            <div class="spinner-border text-light" style="width: 3rem; height: 3rem;" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else
    {
        @if (_data.Announcements.Count > 0)
        {
            <div class="announcements-bar px-4 py-2">
                <div class="d-flex align-items-center gap-3">
                    <span class="badge bg-warning text-dark fs-6"><i class="bi bi-megaphone-fill me-1"></i>Announcements</span>
                    <div class="announcements-scroll">
                        @foreach (var a in _data.Announcements)
                        {
                            <span class="announcement-item">
                                <strong>@a.Title</strong> &mdash; @a.Content
                            </span>
                        }
                    </div>
                </div>
            </div>
        }

        <div class="office-grid p-4">
            @foreach (var office in _data.Offices.OrderBy(x => x.UnitNumber))
            {
                <div class="office-card">
                    <div class="unit-badge">@office.UnitNumber</div>
                    <h3 class="office-name">@office.Name</h3>
                    @if (office.Names.Count > 0)
                    {
                        @foreach (var name in office.Names)
                        {
                            <p class="person-name"><i class="bi bi-person-fill me-1"></i>@name</p>
                        }
                    }
                    @if (!string.IsNullOrEmpty(office.PhoneNumber))
                    {
                        <p class="person-name"><i class="bi bi-telephone-fill me-1"></i>@office.PhoneNumber</p>
                    }
                    @if (!string.IsNullOrEmpty(office.Note))
                    {
                        <p class="person-name"><i class="bi bi-sticky-fill me-1"></i>@office.Note</p>
                    }
                </div>
            }
        </div>

        @if (_data.Offices.Count == 0)
        {
            <div class="text-center text-white-50 mt-5">
                <i class="bi bi-inbox fs-1"></i>
                <p class="fs-4 mt-2">No offices configured yet</p>
            </div>
        }
    }

    <footer class="display-footer px-4 py-2">
        <small class="text-white-50">
            @if (!string.IsNullOrEmpty(_data?.KioskName))
            {
                @_data.KioskName<text> &bull; </text>
            }
            Auto-refreshes every 5 minutes &bull; Last updated: @_lastUpdated.ToString("h:mm:ss tt")
        </small>
    </footer>
</div>

@code {
    private PublicDisplayDto? _data;
    private Timer? _refreshTimer;
    private Timer? _clockTimer;
    private DateTime _lastUpdated = DateTime.Now;

    private string BackgroundStyle => _data?.BackgroundImageUrl is not null
        ? $"background-image: url('{_data.BackgroundImageUrl}');"
        : "";

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
        // Refresh data every 5 minutes
        _refreshTimer = new Timer(async _ =>
        {
            await LoadData();
            await InvokeAsync(StateHasChanged);
        }, null, TimeSpan.FromMinutes(5), TimeSpan.FromMinutes(5));

        // Update clock every 30 seconds
        _clockTimer = new Timer(_ =>
        {
            InvokeAsync(StateHasChanged);
        }, null, TimeSpan.FromSeconds(30), TimeSpan.FromSeconds(30));
    }

    private async Task LoadData()
    {
        try
        {
            _data = await Api.GetPublicDisplayAsync();
            _lastUpdated = DateTime.Now;
        }
        catch
        {
            // ignored
        }
    }

    public void Dispose()
    {
        _refreshTimer?.Dispose();
        _clockTimer?.Dispose();
    }
}
